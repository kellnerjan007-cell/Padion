{
  "cli": {
    "version": ">= 5.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": false
      }
    },
    "preview": {
      "distribution": "store",
      "credentialsSource": "remote",
      "ios": {
        "buildConfiguration": "Release",
        "autoIncrement": true
      }
    },
    "production": {
      "distribution": "store",
      "credentialsSource": "remote",
      "ios": {
        "buildConfiguration": "Release"
      }
    }
  },
  "submit": {
    "preview": {
      "ios": {
        "ascAppId": "6760897094"
      }
    },
    "production": {
      "ios": {}
    }
  }
}
